# ---- Postgres ----
POSTGRES_USER=thbot
POSTGRES_PASSWORD=thbot
POSTGRES_DB=thbot
# async driver for the app, sync driver (psycopg) is derived in alembic env
DATABASE_URL=postgresql+asyncpg://thbot:thbot@db:5432/thbot

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Auth (JWT) ----
JWT_SECRET=change-me-in-prod-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14

# ---- Anthropic (Claude) ----
# 비워두면 Claude 래퍼는 오프라인 스텁 모드로 동작(구조/비용 로깅만 검증).
ANTHROPIC_API_KEY=

# ---- Voyage (RAG 임베딩/rerank) ----  비우면 결정적 스텁
VOYAGE_API_KEY=

# ---- Notion (매매일지 임포트) ----  내부 integration 토큰, 비우면 스텁 7건
NOTION_API_KEY=
NOTION_JOURNAL_DATABASE_ID=594dbad241f883f0b40481906cd4b123

# ---- 모닝리포트 기준값 (평일 지정시각 1회 생성) ----
MORNING_ENABLED=true
MORNING_HOUR=6
MORNING_MINUTE=30
MORNING_MARKETS=US,KR
MORNING_STYLE=swing            # scalping | swing | long
MORNING_TOP_THEMES=5
MORNING_MIN_THEME_SCORE=0      # 이 점수 미만 테마 제외(0=전부)
MORNING_USE_OPUS=false         # false=Sonnet(저비용 권장), true=Opus 심층

# ---- 비용 절감(혼자 쓰기 최적화) ----
LLM_PROMPT_CACHE=true          # 시스템 프리픽스 프롬프트 캐싱(입력비 0.1x)
RESEARCH_CACHE_SAME_DAY=true   # 같은 종목·질문·당일 리포트 재사용(LLM 0원)
RAG_TOP_K=4                    # 합성에 넣는 RAG 청크 수(작을수록 입력비↓)

# ---- App ----
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
